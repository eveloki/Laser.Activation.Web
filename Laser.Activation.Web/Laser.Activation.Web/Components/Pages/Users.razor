@using Microsoft.EntityFrameworkCore

@page "/users"
@rendermode InteractiveServer
@inject AppDbContext DbContext
@inject IRedisTokenService RedisTokenService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>用户列表 - 激活管理系统</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>用户管理</h2>
    <a href="/user-create" class="btn btn-primary">创建用户</a>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">加载中...</span>
        </div>
    </div>
}
else if (users.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>用户名</th>
                    <th>角色</th>
                    <th>创建时间</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.Username</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-danger">管理员</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">普通用户</span>
                            }
                        </td>
                        <td>@user.CreatedTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => ConfirmDelete(user.Id, user.Username)"
                                    disabled="@(user.Username == "admin")">
                                删除
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info text-center">暂无用户</div>
}

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert alert-success alert-dismissible fade show mt-3">
        @statusMessage
        <button type="button" class="btn-close" @onclick="() => statusMessage = string.Empty"></button>
    </div>
}

@code {
    private List<User> users = new();
    private bool isLoading = false;
    private string statusMessage = "";
    private IJSObjectReference? module;
    private int? currentUserId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/auth.js");
            var valid = await module.InvokeAsync<bool>("validateAuth");
            if (!valid) return;

            var role = await module.InvokeAsync<string>("getUserRole");
            if (role != "Admin")
            {
                Navigation.NavigateTo("/home", forceLoad: true);
                return;
            }

            var idStr = await module.InvokeAsync<string>("getUserId");
            if (int.TryParse(idStr, out var id))
                currentUserId = id;

            await LoadUsers();
            StateHasChanged();
        }
    }

    private async Task LoadUsers()
    {
        isLoading = true;
        try
        {
            users = await DbContext.Users.OrderBy(u => u.Id).ToListAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ConfirmDelete(int userId, string username)
    {
        if (userId == currentUserId)
        {
            statusMessage = "不能删除当前登录的用户";
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"确定要删除用户 \"{username}\" 吗？");
        if (!confirmed) return;

        try
        {
            var user = await DbContext.Users.FindAsync(userId);
            if (user != null)
            {
                RedisTokenService.DeleteUserTokens(userId);
                DbContext.Users.Remove(user);
                await DbContext.SaveChangesAsync();
                statusMessage = $"用户 {username} 已删除";
                await LoadUsers();
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"删除失败: {ex.Message}";
        }
    }
}
